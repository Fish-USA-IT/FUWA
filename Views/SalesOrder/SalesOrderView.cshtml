@{
    ViewData["Title"] = "Sales Order View";
}

<div class="container mt-4">
    <div class="card bg-light shadow-sm">
        <div class="card-body">

            <h1>Sales Order</h1>

            @if (Model.SalesOrder is null)
            {
                <div class="alert alert-warning">
                    Sales order not found.
                </div>
            }
            else
            {
                @await Component.InvokeAsync("ObjectDetails", new
                {
                    source = Model.SalesOrder,
                    title = "Sales Order Details",
                    includedFields = new[]
                    {
                        "#Order Information#",
                        "TranId",
                        "TranDate",
                        "Status",

                        "#Customer#",
                        "CustomerName",
                        "EntityId",
                        "",

                        "#Totals#",
                        "Total"
                    }
                })

                <div class="card shadow-sm bg-white mt-4">
                    <div class="card-body">
                        <h3>Items</h3>

                        @if (Model.ItemLines.Count == 0)
                        {
                            <p class="text-muted mb-0">
                                No item lines found.
                            </p>
                        }
                        else
                        {
                            <table class="table table-striped table-hover">
                                <thead>
                                    <tr>
                                        <th>Item</th>
                                        <th>Quantity</th>
                                        <th>Rate</th>
                                        <th>Amount</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var line in Model.ItemLines)
                                    {
                                        <tr>
                                            <td>
                                                @(string.IsNullOrWhiteSpace(line.ItemDisplayName)
                                                ? line.Item
                                                : line.ItemDisplayName)
                                            </td>
                                            <td>@line.Quantity</td>
                                            <td>@line.Rate</td>
                                            <td>@line.Amount</td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        }
                    </div>
                </div>
            }

            <div class="mt-3">
                <a asp-controller="SalesOrder"
                   asp-action="Search"
                   class="btn btn-outline-secondary">
                    Back to Search
                </a>
            </div>

        </div>
    </div>
</div>