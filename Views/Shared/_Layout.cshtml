@using Microsoft.AspNetCore.Http
@{
    var controller = ViewContext.RouteData.Values["controller"]?.ToString();
}

<!DOCTYPE html>
    <html lang="en">
    <head>
        <meta charset="utf-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        <title>@ViewData["Title"] - FishUsaWebApp</title>
        <script type="importmap"></script>
        <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
        <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
        <link rel="stylesheet" href="~/FishUsaWebApp.styles.css" asp-append-version="true" />
    </head>
    @{
        var employeeId = Context.Session.GetString("EmployeeId");
        var firstName = Context.Session.GetString("EmployeeFirstName");
        var lastName = Context.Session.GetString("EmployeeLastName");
    
        var isLoggedIn = !string.IsNullOrWhiteSpace(employeeId);
    }
    <body>
        @if (controller != "Auth")
        {
        <header>
            <nav class="navbar navbar-expand-sm navbar-toggleable-sm navbar-light bg-white border-bottom box-shadow mb-3">
                <div class="container-fluid">
                    <a class="navbar-brand" asp-area="" asp-controller="Home" asp-action="Index">FishUsaWebApp</a>
                    <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                            aria-expanded="false" aria-label="Toggle navigation">
                        <span class="navbar-toggler-icon"></span>
                    </button>
                    <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                        <ul class="navbar-nav flex-grow-1">
                            @if (isLoggedIn)
                            {
                                <li class="nav-item">
                                    <a class="nav-link text-dark"
                                       asp-controller="Home"
                                       asp-action="Index">
                                        Home
                                    </a>
                                </li>
                            }
                        </ul>

                        @if (isLoggedIn)
                        {
                            <div class="d-flex align-items-center gap-3">
                                <span class="text-muted">
                                    Logged in as
                                    <strong>@firstName @lastName</strong>
                                </span>

                                <button id="themeToggle"
                                        type="button"
                                        class="btn btn-outline-secondary btn-sm">
                                    Dark Mode
                                </button>

                                <form asp-controller="Auth"
                                      asp-action="Logout"
                                      method="post"
                                      class="m-0">
                                    @Html.AntiForgeryToken()

                                    <button type="submit"
                                            class="btn btn-outline-danger btn-sm">
                                        Logout
                                    </button>
                                </form>

                            </div>
                        }

                    </div>
                </div>
            </nav>
        </header>
        }
        <div class="container">
            <main role="main" class="pb-3">
                @RenderBody()
            </main>
        </div>
    
        <footer class="border-top footer text-muted">
            <div class="container">
                &copy; 2026 - FishUsaWebApp - <a asp-area="" asp-controller="Home" asp-action="Privacy">Privacy</a>
            </div>
        </footer>
        <script src="~/lib/jquery/dist/jquery.min.js"></script>
        <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
        <script src="~/js/site.js" asp-append-version="true"></script>
        <script>
            const savedTheme = localStorage.getItem("theme");

            if (savedTheme === "dark") {
            document.body.classList.add("dark-mode");
            }

            document.addEventListener("DOMContentLoaded", () => {
            const button = document.getElementById("themeToggle");

            updateButtonText();

            button?.addEventListener("click", () => {
            document.body.classList.toggle("dark-mode");

            const isDark =
            document.body.classList.contains("dark-mode");

            localStorage.setItem(
            "theme",
            isDark ? "dark" : "light");

            updateButtonText();
            });

            function updateButtonText() {
            button.textContent =
            document.body.classList.contains("dark-mode")
            ? "Light Mode"
            : "Dark Mode";
            }
            });
        </script>
    </body>
</html>
