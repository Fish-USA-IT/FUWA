@model FishUsaWebApp.Models.ViewModels.CommonModels.SearchPageViewModel
@using FishUsaWebApp.ViewComponents

@{
    var rows = SearchResultsViewComponent.GetRows(Model.Source);
}

<div class="container mt-4">
    <div class="card bg-light shadow-sm">
        <div class="card-body">

            <h1>@Model.Title</h1>

            @if (!string.IsNullOrWhiteSpace(Model.Description))
            {
                <p class="text-muted">
                    @Model.Description
                </p>
            }

            <div class="card shadow-sm bg-white mt-4">
                <div class="card-body">
                    <form asp-controller="@Model.Controller"
                          asp-action="@Model.Action"
                          method="get">

                        <input type="hidden" name="page" value="1" />
                        <input type="hidden" name="pageSize" value="@Model.PageSize" />

                        <div id="searchFilterRows">
                            @for (var i = 0; i < Model.ActiveFilters.Count; i++)
                            {
                                var activeFilter = Model.ActiveFilters[i];

                                <div class="row mb-2 search-filter-row">
                                    <div class="col-md-4 mb-2">
                                        @if (i == 0)
                                        {
                                            <label class="form-label">
                                                Search By
                                            </label>
                                        }

                                        <select name="ActiveFilters[@i].Filter"
                                                class="form-select search-filter-select">
                                            @foreach (var filter in Model.SearchFilters)
                                            {
                                                <option value="@filter.Value"
                                                        data-placeholder="@filter.Placeholder"
                                                        selected="@(filter.Value == activeFilter.Filter)">
                                                    @filter.Text
                                                </option>
                                            }
                                        </select>
                                    </div>

                                    <div class="col-md-7 mb-2">
                                        @if (i == 0)
                                        {
                                            <label class="form-label">
                                                Search Value
                                            </label>
                                        }

                                        <input name="ActiveFilters[@i].Value"
                                               value="@activeFilter.Value"
                                               class="form-control search-filter-input"
                                               placeholder="Enter search value" />
                                    </div>

                                    <div class="col-md-1 mb-2 d-flex align-items-end">
                                        @if (i == 0)
                                        {
                                            <button type="button"
                                                    class="btn btn-outline-success add-filter-row w-100">
                                                +
                                            </button>
                                        }
                                        else
                                        {
                                            <button type="button"
                                                    class="btn btn-outline-danger remove-filter-row w-100">
                                                -
                                            </button>
                                        }
                                    </div>
                                </div>
                            }
                        </div>

                        <button type="submit"
                                class="btn btn-primary mt-2">
                            Search
                        </button>

                        <a asp-controller="Home"
                           asp-action="Index"
                           class="btn btn-outline-secondary mt-2">
                            Back
                        </a>
                    </form>
                </div>
            </div>

            @if (Model.HasSearched)
            {
                <div class="card shadow-sm bg-white mt-4">
                    <div class="card-body">

                        <div class="d-flex justify-content-between align-items-center mb-3">
                            <h3 class="mb-0">Results</h3>

                            <span class="text-muted">
                                Showing @rows.Count result(s)
                            </span>
                        </div>

                        @if (rows.Any())
                        {
                            <table class="table table-striped table-hover">
                                <thead>
                                    <tr>
                                        @foreach (var column in Model.Columns)
                                        {
                                            <th>@column.Header</th>
                                        }

                                        <th></th>
                                    </tr>
                                </thead>

                                <tbody>
                                    @foreach (var row in rows)
                                    {
                                        var idValue =
                                            SearchResultsViewComponent.GetPropertyValue(
                                                row,
                                                Model.IdPropertyName);

                                        <tr>
                                            @foreach (var column in Model.Columns)
                                            {
                                                <td>
                                                    @SearchResultsViewComponent.GetPropertyValue(
                                                                                                                                            row,
                                                                                                                                            column.PropertyName)
                                                </td>
                                            }

                                            <td class="text-end">
                                                <a asp-controller="@Model.ViewController"
                                                asp-action="@Model.ViewAction"
                                                asp-route-id="@idValue"
                                                class="btn btn-primary btn-sm">
                                                    View
                                                </a>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        }
                        else
                        {
                            <div class="card shadow-sm bg-white mt-4">
                                <div class="card-body">
                                    <span class="text-muted">
                                        No results found.
                                    </span>
                                </div>
                            </div>
                        }

                        <div class="d-flex justify-content-between align-items-center mt-3">
                            <div>
                                Page @Model.Page
                            </div>

                            <div class="btn-group">
                                @if (Model.HasPreviousPage)
                                {
                                    <a asp-controller="@Model.Controller"
                                       asp-action="@Model.Action"
                                       asp-route-page="@(Model.Page - 1)"
                                       asp-route-pageSize="@Model.PageSize"
                                       class="btn btn-outline-secondary">
                                        Previous
                                    </a>
                                }

                                @if (Model.HasNextPage)
                                {
                                    <a asp-controller="@Model.Controller"
                                       asp-action="@Model.Action"
                                       asp-route-page="@(Model.Page + 1)"
                                       asp-route-pageSize="@Model.PageSize"
                                       class="btn btn-outline-secondary">
                                        Next
                                    </a>
                                }
                            </div>
                        </div>

                    </div>
                </div>
            }

        </div>
    </div>
</div>

<script>
    document.addEventListener("DOMContentLoaded", function () {
        updateAllSearchPlaceholders();
        reindexSearchRows();
    });

    document.addEventListener("change", function (event) {
        if (!event.target.classList.contains("search-filter-select")) {
            return;
        }

        updateSearchPlaceholder(event.target);
    });

    document.addEventListener("click", function (event) {
        if (event.target.classList.contains("add-filter-row")) {
            addSearchFilterRow();
            return;
        }

        if (event.target.classList.contains("remove-filter-row")) {
            event.target.closest(".search-filter-row")?.remove();
            reindexSearchRows();
        }
    });

    function addSearchFilterRow() {
        const container = document.getElementById("searchFilterRows");

        if (!container) {
            return;
        }

        const rows = container.querySelectorAll(".search-filter-row");

        if (rows.length === 0) {
            return;
        }

        const clone = rows[rows.length - 1].cloneNode(true);
        
        clone.querySelectorAll("label").forEach(function (label) {
            label.remove();
        });

        clone.querySelectorAll("input").forEach(function (input) {
            input.value = "";
        });

        const button = clone.querySelector("button");

        if (button) {
            button.classList.remove("btn-outline-success");
            button.classList.remove("add-filter-row");

            button.classList.add("btn-outline-danger");
            button.classList.add("remove-filter-row");

            button.textContent = "-";
        }

        container.appendChild(clone);

        reindexSearchRows();
        updateAllSearchPlaceholders();
    }

    function reindexSearchRows() {
        const rows = document.querySelectorAll(".search-filter-row");

        rows.forEach(function (row, index) {
            const select = row.querySelector(".search-filter-select");
            const input = row.querySelector(".search-filter-input");

            if (select) {
                select.name = `ActiveFilters[${index}].Filter`;
            }

            if (input) {
                input.name = `ActiveFilters[${index}].Value`;
            }
        });
    }

    function updateAllSearchPlaceholders() {
        document.querySelectorAll(".search-filter-select").forEach(function (select) {
            updateSearchPlaceholder(select);
        });
    }

    function updateSearchPlaceholder(select) {
        const row = select.closest(".search-filter-row");

        if (!row) {
            return;
        }

        const input = row.querySelector(".search-filter-input");

        if (!input) {
            return;
        }

        const selectedOption = select.options[select.selectedIndex];

        input.placeholder =
            selectedOption.getAttribute("data-placeholder") || "Enter search value";
    }
</script>