<div class="card shadow-sm bg-white">
    <div class="card-body">
        <h3 class="mb-3">@Model.Title</h3>

        @if (Model.Source is null)
        {
            <p class="text-muted mb-0">No data found.</p>
        }
        else if (Model.Fields.Count == 0)
        {
            <p class="text-muted mb-0">No displayable fields found.</p>
        }
        else
        {
            <div class="mb-3">
                <label class="form-label">Filter Fields</label>
                <input type="text"
                       class="form-control object-details-filter"
                       placeholder="Type to filter fields..." />
            </div>
            <div class="row object-details-grid">
                @foreach (var field in Model.Fields)
                {
                    if (field.IsHeader)
                    {
                        <div class="col-12 mt-3 mb-2 object-details-header"
                             data-field-name="@field.Value"
                             data-field-value="@field.Value">
                            <h4 class="border-bottom pb-2">
                                @field.Value
                            </h4>
                        </div>

                        continue;
                    }

                    <div class="col-md-4 mb-3 object-details-field"
                         data-field-name="@field.Label"
                         data-field-value="@field.Value">
                        @if (field.IsEmpty)
                        {
                            <div class="h-100"></div>
                        }
                        else
                        {
                            <div class="border rounded p-2 h-100">
                                <div class="text-muted small">
                                    @field.Label
                                </div>
                                <div class="text-break">
                                    @field.Value
                                </div>
                            </div>
                        }
                    </div>
                }
            </div>
        }
    </div>
</div>