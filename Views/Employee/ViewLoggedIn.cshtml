@model FishUsaWebApp.Models.ViewModels.EmployeeModels.EmployeeDetailsViewModel

@{
    ViewData["Title"] = "My Employee Record";
}

<div class="container mt-4">
    <div class="card bg-light shadow-lg">
        <div class="card-body">

            <h1>My Employee Record</h1>

            <p class="text-muted">
                Viewing the currently logged in employee.
            </p>

            @await Component.InvokeAsync("ObjectDetails", new
            {
                source = Model.Employee,
                title = "Employee Details",
                includedFields = new[]
                {
                    "#Identity#",
                    "Id",
                    "EntityId",
                    "Supervisor.RefName",
                    "",
                    "Email",
                
                    "#Personal Info#",
                    "FirstName",
                    "LastName",
                
                    "#Employment#",
                    "Title",
                    "custentity15",
                    "Location.RefName"
                }
            })

            <div class="mt-3">
                <a asp-controller="Home"
                   asp-action="Index"
                   class="btn btn-outline-secondary">
                    Back to Dashboard
                </a>
            </div>

        </div>
    </div>
</div>